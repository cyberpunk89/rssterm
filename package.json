{
  "name": "rssterm",
  "version": "1.0.0",
  "description": "A terminal RSS reader built with Ink + termcn + Catppuccin Mocha",
  "keywords": ["rss", "terminal", "ink", "cli", "reader"],
  "scripts": {
    "start": "tsx src/index.tsx",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "cli-spinners": "^3.4.0",
    "ink": "^7.0.1",
    "js-yaml": "^4.1.1",
    "mnemonist": "^0.40.3",
    "react": "^19.2.5",
    "rss-parser": "^3.13.0",
    "terminal-image": "^4.3.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
